# Production environment settings
# IMPORTANT: Replace these values with your actual production credentials on the server
# DO NOT commit actual secrets to version control

# Database Configuration
DATABASE_URL=sqlite:///./avaliador.db

# JWT Configuration 
JWT_SECRET_KEY=replace_with_secure_key_on_server
JWT_REFRESH_SECRET_KEY=replace_with_secure_key_on_server
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# OpenAI Configuration
OPENAI_API_KEY=replace_with_api_key_on_server

# Email Configuration
EMAIL_HOST=smtp.hostinger.com
EMAIL_PORT=587
EMAIL_USERNAME=seu_email@avaliadorprompt.com.br
EMAIL_PASSWORD=replace_with_password_on_server
EMAIL_FROM=seu_email@avaliadorprompt.com.br

# Payment Gateway Configuration
PAYMENT_API_KEY=replace_with_api_key_on_server
PAYMENT_API_URL=https://api.payment-gateway.com

# Application Settings
DEBUG=False
ALLOWED_HOSTS=avaliadorprompt.com.br,www.avaliadorprompt.com.br
CORS_ORIGINS=https://avaliadorprompt.com.br,https://www.avaliadorprompt.com.br
